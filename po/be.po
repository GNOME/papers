#. Manually set name and icon
#: data/org.gnome.Papers.desktop.in.in:2 data/org.gnome.Papers.metainfo.xml.in.in:9
#: shell/resources/pps-document-view.blp:88 shell/resources/pps-loader-view.blp:10
#: shell/src/application.rs:47 shell/src/application.rs:389
msgid "Document Viewer"
msgstr "Праглядальнік дакументаў"

#: data/org.gnome.Papers.desktop.in.in:3
msgid "View multi-page documents"
msgstr "Прагляд шматстаронкавых дакументаў"

#. Translators: Search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
#: data/org.gnome.Papers.desktop.in.in:5
msgid "pdf;djvu;tiff;document;presentation;viewer;papers;"
msgstr "pdf;djvu;tiff;document;presentation;viewer;papers;дакумент;прэзентацыя;праглядальнік;"

#: data/org.gnome.Papers.desktop.in.in:20
msgid "New Window"
msgstr "Новае акно"

#: data/org.gnome.Papers.gschema.xml:14
msgid "Override document restrictions"
msgstr "Не зважаць на абмежаванні дакумента"

#: data/org.gnome.Papers.gschema.xml:15
msgid "Override document restrictions, like restriction to copy or to print."
msgstr "Не зважаць на абмежаванні дакумента тыпу забароны капіявання або друку."

#: data/org.gnome.Papers.gschema.xml:19
msgid "The URI of the directory last used to open or save a document"
msgstr "URI-адрас каталога, ужытага пры апошнім адкрыцці ці захаванні дакумента"

#: data/org.gnome.Papers.gschema.xml:23
msgid "The URI of the directory last used to save a picture"
msgstr "URI-адрас каталога, ужытага пры апошнім захаванні відарыса"

#: data/org.gnome.Papers.gschema.xml:27
msgid "Page cache size in MiB"
msgstr "Памер кэш-памяці старонак у Мебібайтах"

#: data/org.gnome.Papers.gschema.xml:28
msgid "The maximum size that will be used to cache rendered pages, limits maximum zoom level."
msgstr ""
"Максімальны памер кэш-памяці для захавання апрацаваных старонак, абмяжоўвае магчымы "
"ўзровень маштабавання."

#: data/org.gnome.Papers.gschema.xml:32
msgid "Allow links to change the zoom level."
msgstr "Дазволіць спасылкам мяняць маштабаванне."

#: data/org.gnome.Papers.gschema.xml:44
msgid "Check spelling when writing annotation notes or filling text forms."
msgstr "Правяраць правапіс падчас напісання нататак або запаўнення тэкставых форм."

#: data/org.gnome.Papers.gschema.xml:48
msgid "Show a side bar next to the document to help navigate the document."
msgstr "Паказваць побач з дакументам бакавую панэль, каб спрасціць пераход па яго змесце."

#: data/org.gnome.Papers.gschema.xml:61
msgid "Set the default zoom level to display a document."
msgstr "Задаць прадвызначаны ўзровень маштабавання для вываду дакумента."

#: data/org.gnome.Papers.gschema.xml:65
msgid "Display the document as a continuous stream of pages instead of page at a time."
msgstr "Паказваць дакумент як бесперапынную чараду старонак замест паказу па адной."

#: data/org.gnome.Papers.gschema.xml:69
msgid "Show two pages side by side."
msgstr "Паказваць па дзве старонкі побач."

#: data/org.gnome.Papers.gschema.xml:73
msgid "Show the first page (odd page) on the left (when displaying two pages side by side)"
msgstr "Паказ першай (усіх няцотных) старонкі злева (пры вывадзе па дзве старонкі побач)"

#: data/org.gnome.Papers.gschema.xml:113
msgid "Previewer window height"
msgstr "Вышыня акна папярэдняга прагляду"

#: data/org.gnome.Papers.gschema.xml:117
msgid "Previewer window width"
msgstr "Шырыня акна папярэдняга прагляду"

#: data/org.gnome.Papers.gschema.xml:121
msgid "Previewer window maximized state"
msgstr "Стан акна папярэдняга прагляду – разгорнута."

#: data/org.gnome.Papers.metainfo.xml.in.in:10
msgid "Read documents"
msgstr "Чытанне дакументаў"

#: data/org.gnome.Papers.metainfo.xml.in.in:12
msgid ""
"A document viewer for the GNOME desktop. You can view, search or annotate documents in many "
"different formats."
msgstr ""
"Праглядальнік дакументаў для асяроддзя GNOME. Прагляд, пошук і стварэнне нататак для "
"дакументаў у разнастайных фарматах."

#: data/org.gnome.Papers.metainfo.xml.in.in:13
msgid ""
"Papers supports documents in: PDF, DjVu, TIFF, and Comic Books archives (CBR, CBT, CBZ, "
"CB7)."
msgstr ""
"Papers падтрымлівае наступныя фарматы дакументаў: PDF, DjVu, TIFF і архівы коміксаў (CBR, "
"CBT, CBZ, CB7)."

#: data/org.gnome.Papers.metainfo.xml.in.in:65
msgid "A clear, simple, and modern UI"
msgstr "Просты зразумелы і сучасны інтэрфейс карыстальніка"

#: data/org.gnome.Papers.metainfo.xml.in.in:69
msgid "A mobile-friendly UI"
msgstr "Інтэрфейс, сумяшчальны з мабільнымі прыладамі"

#: data/org.gnome.Papers.metainfo.xml.in.in:73
msgid "A modern and colorful annotation list"
msgstr "Сучасны каляровы спіс нататак"

#: data/org.gnome.Papers.metainfo.xml.in.in:77
msgid "Big thumbnails in the sidebar"
msgstr "Вялікія мініяцюры на бакавой панэлі"

#: data/org.gnome.Papers.metainfo.xml.in.in:81
msgid "All search actions are contained in the sidebar"
msgstr "Усе пошукавыя дзеянні размешчаны на бакавой панэлі"

#: data/org.gnome.Papers-previewer.desktop.in.in:2
msgid "Print Preview"
msgstr "Папярэдні прагляд друку"

#: data/org.gnome.Papers-previewer.desktop.in.in:3
msgid "Preview before printing"
msgstr "Папярэдні прагляд перад друкам"

