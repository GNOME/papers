#. Manually set name and icon
#: data/org.gnome.Papers.desktop.in.in:2 data/org.gnome.Papers.metainfo.xml.in.in:9 shell/resources/pps-document-view.blp:87 shell/resources/pps-loader-view.blp:10 shell/src/application.rs:47 shell/src/application.rs:389
msgid "Document Viewer"
msgstr "Прегледач докумената"

#: data/org.gnome.Papers.desktop.in.in:3
msgid "View multi-page documents"
msgstr "Прегледајте вишестраничне документе"

#. Translators: Search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
#: data/org.gnome.Papers.desktop.in.in:5
msgid "pdf;djvu;tiff;document;presentation;viewer;papers;"
msgstr "pdf;djvu;tiff;document;presentation;viewer;papers;пдф;дјву;дежави;тифф;документ;презентација;приказивање;преглед;папири;dežavi;dokument;prezentacija;prikazivanje;pregled;papiri;евинс;"

#: data/org.gnome.Papers.desktop.in.in:20
msgid "New Window"
msgstr "Нови прозор"

#: data/org.gnome.Papers.gschema.xml:14
msgid "Override document restrictions"
msgstr "Превазилази ограничења документа"

#: data/org.gnome.Papers.gschema.xml:15
msgid "Override document restrictions, like restriction to copy or to print."
msgstr "Превазилази ограничења која документ садржи, као што је забрана умножавања или штампања."

#: data/org.gnome.Papers.gschema.xml:19
msgid "The URI of the directory last used to open or save a document"
msgstr "Путања последњег директоријума коришћеног за отварање или чување документа"

#: data/org.gnome.Papers.gschema.xml:23
msgid "The URI of the directory last used to save a picture"
msgstr "Путања последњег директоријума коришћеног за чување слике"

#: data/org.gnome.Papers.gschema.xml:27
msgid "Page cache size in MiB"
msgstr "Величина оставе странице у MiB"

#: data/org.gnome.Papers.gschema.xml:28
msgid "The maximum size that will be used to cache rendered pages, limits maximum zoom level."
msgstr "Највећа величина која ће бити коришћена за смештај исцртаних страница, ограничавајући највећи ниво увеличања."

#: data/org.gnome.Papers.gschema.xml:32
msgid "Allow links to change the zoom level."
msgstr "Омогућава везама да измене ниво увеличања."

#: data/org.gnome.Papers.gschema.xml:43
msgid "Check spelling when writing annotation notes or filling text forms."
msgstr "Проверава писање приликом попуњавања забелешки или образаца за текст."

#: data/org.gnome.Papers.gschema.xml:47
msgid "Show a side bar next to the document to help navigate the document."
msgstr "Приказује бочну површ поред документа за помоћ при навигацији кроз документ."

#: data/org.gnome.Papers.gschema.xml:60
msgid "Set the default zoom level to display a document."
msgstr "Поставља подразумевани ниво увеличања за приказ документа."

#: data/org.gnome.Papers.gschema.xml:64
msgid "Display the document as a continuous stream of pages instead of page at a time."
msgstr "Приказује документ уцело уместо да се приказује по једна страница."

#: data/org.gnome.Papers.gschema.xml:68
msgid "Show two pages side by side."
msgstr "Приказује две странице једну поред друге."

#: data/org.gnome.Papers.gschema.xml:72
msgid "Show the first page (odd page) on the left (when displaying two pages side by side)"
msgstr "Приказује прву страницу (непарну) са леве стране (када се приказују по две странице једна поред друге)"

#: data/org.gnome.Papers.metainfo.xml.in.in:10
msgid "Read documents"
msgstr "Читајте документе"

#: data/org.gnome.Papers.metainfo.xml.in.in:12
msgid "A document viewer for the GNOME desktop. You can view, search or annotate documents in many different formats."
msgstr "Прегледач докумената за Гномову површ. Можете гледати, претраживати или обележавати садржај докумената разних формата."

#: data/org.gnome.Papers.metainfo.xml.in.in:13
msgid "Papers supports documents in: PDF, DjVu, TIFF, and Comic Books archives (CBR, CBT, CBZ, CB7)."
msgstr "Папири подржавају документе у форматима: ПДФ, ДјВу, ТИФФ и архиве стрипова (CBR, CBT, CBZ, CB7)."

#: data/org.gnome.Papers.metainfo.xml.in.in:29
msgid "A clear, simple, and modern UI"
msgstr "Једноставно, прегледно и савремено графичко прочеље"

#: data/org.gnome.Papers.metainfo.xml.in.in:33
msgid "A mobile-friendly UI"
msgstr "Прочеље прилагођено за мобиле уређаје"

#: data/org.gnome.Papers.metainfo.xml.in.in:37
msgid "A modern and colorful annotation list"
msgstr "Савремен и шаренолик списак забелешки"

#: data/org.gnome.Papers.metainfo.xml.in.in:41
msgid "Big thumbnails in the sidebar"
msgstr "Велике сличице у бочној површи"

#: data/org.gnome.Papers.metainfo.xml.in.in:45
msgid "All search actions are contained in the sidebar"
msgstr "Све радње за претрагу се налазе у бочној површи"

#: data/org.gnome.Papers-previewer.desktop.in.in:2
msgid "Print Preview"
msgstr "Претпреглед штампе"

#: data/org.gnome.Papers-previewer.desktop.in.in:3
msgid "Preview before printing"
msgstr "Преглед пре штампања"

